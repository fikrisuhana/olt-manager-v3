# ============================================================
# GPON Manager — Konfigurasi
# Salin file ini ke .env lalu sesuaikan nilainya
# ============================================================

# URL publik aplikasi (dengan trailing slash)
APP_URL=http://localhost:8080/

# Port yang diekspos ke host
APP_PORT=8080

# CI4 environment: production | development
APP_ENV=production

# Database
DB_PASS=gpon_secret
DB_ROOT_PASS=root_secret

# Enkripsi session CI4
# Generate dengan: php -r "echo bin2hex(random_bytes(32));"
# Biarkan kosong untuk auto-generate (tidak direkomendasikan di production)
ENCRYPTION_KEY=
